# Copy this file to .env.development and .env.production and fill in real values.
# NEVER commit .env.development or .env.production to git.

NODE_ENV=development

# Server
PORT=5000

# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# Redis
REDIS_URL=redis://HOST:6379
REDIS_HOST=HOST
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=HOST
MINIO_PORT=9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# JWT – generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_hex_string

# OTP Token Secret
OTP_SECRET=your_64_char_random_hex_string

# Twilio (get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
